# --- LLM provider (Grok via xAI, routed through Cognee's custom/OpenAI-compatible provider) ---
LLM_PROVIDER=custom
LLM_MODEL=xai/grok-4
LLM_API_KEY=your_xai_api_key_here
LLM_ENDPOINT=https://api.x.ai/v1

# --- Embedding provider ---

EMBEDDING_PROVIDER=fastembed
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5
EMBEDDING_DIMENSIONS=384

# --- Cognee storage paths (local filesystem for development) ---
COGNEE_SYSTEM_ROOT=.cognee_system
COGNEE_DATA_ROOT=.cognee_data

# --- Backend server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# --- CORS (frontend origin) ---
FRONTEND_ORIGIN=http://localhost:3000